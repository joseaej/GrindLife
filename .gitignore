# ==============================================================================
# 👾 GrindLife - Monorepo .gitignore (Java Backend & Flutter Frontend)
# ==============================================================================

# ========================================
# 1. Sistema Operativo
# ========================================
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ========================================
# 2. Secretos y Entornos
# ========================================
.env
.env.*
*.pem
*.key
application-local.properties
application-local.yml
**/android/key.properties
**/android/app/google-services.json

# ========================================
# 3. IDEs y Editores
# ========================================
# IntelliJ IDEA / Android Studio
.idea/
*.iml
*.iws
*.ipr
out/
# VS Code
.vscode/
*.code-workspace
# Eclipse
.project
.classpath
.factorypath
.settings/
bin/

# ========================================
# 4. Backend (Java / Spring Boot / Maven)
# ========================================
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
dependency-reduced-pom.xml
# Gradle (Por si migras desde Maven)
.gradle/
build/
# Binarios y Logs de Java
*.class
*.jar
*.war
*.ear
*.log
hs_err_pid*

# ========================================
# 5. Frontend (Flutter / Dart)
# ========================================
# Core de Flutter
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
/build/
coverage/
# Flutter Version Management (FVM)
.fvm/flutter_sdk

# Android
**/android/**/gradle-wrapper.jar
!**/android/gradle/wrapper/gradle-wrapper.jar
**/android/.gradle/
**/android/captures/

# iOS
**/ios/.symlinks/
**/ios/Pods/
**/ios/Runner/GeneratedPluginRegistrant.*
**/ios/Runner/flutter_export_environment.sh
**/ios/**/*.pbxuser
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.perspectivev3
**/ios/Runner.xcworkspace/xcuserdata

# Web y Escritorio (Windows / macOS / Linux)
**/build/web/
**/macos/Flutter/ephemeral/
**/macos/Runner/Pods/
**/windows/flutter/ephemeral/
**/linux/flutter/ephemeral/